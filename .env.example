# ============================================================
# SAMADHAAN Health OS — Environment Configuration
# ============================================================
# Copy this file to .env.local and fill in your actual values

# Google Apps Script Web App URL
# Deploy the google-apps-script/Code.js as a web app and paste the deployment URL here
# Format: https://script.google.com/macros/d/{DEPLOYMENT_ID}/usercopy
APPS_SCRIPT_WEB_APP_URL=https://script.google.com/macros/d/YOUR_DEPLOYMENT_ID/usercopy

# Azure Blob Storage Configuration
# Your Azure Storage Account name (without .blob.core.windows.net)
AZURE_ACCOUNT=your_storage_account_name

# Azure Blob Container name where DICOM/PDF files are stored
AZURE_CONTAINER=dicom-container

# Azure SAS Token for read access to blobs
# Format: sv=2020-10-02&ss=b&srt=sco&sp=rwdlac&se=2025-12-31T23:59:59Z&...
AZURE_SAS_TOKEN=sv=2020-10-02&ss=b&srt=sco&sp=rwdlac&...

# ============================================================
# Setup Instructions:
# ============================================================
# 1. Deploy google-apps-script/Code.js to Google Apps Script
# 2. Deploy as web app (New Deployment > Web app)
# 3. Copy the deployment URL to APPS_SCRIPT_WEB_APP_URL
# 4. Set up Azure Storage Account and generate SAS token
# 5. Copy Azure credentials to the variables above
# 6. Rename this file to .env.local
# 7. Run: npm run dev
